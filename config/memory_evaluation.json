{
  "memory": {
    "short_term_limit": 5,
    "long_term_limit": 5,
    "memory_collection": "memory",
    "long_term_collection": "long_term_memory"
  },
  "evaluation": {
    "llm_provider": "deepseek",
    "llm_model": "deepseek-chat",
    "temperature": 0.1,
    "max_tokens": 500,
    "enable_fallback": true
  },
  "output": {
    "save_details": true,
    "report_format": "json",
    "verbose": false
  }
}
